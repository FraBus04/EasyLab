@rendermode InteractiveServer
@using EasyLab.Components.Pages.Articoli.CareLabel
@using EasyLab.Models


@if (loading)
{
	<Loading></Loading>
}

<DxPopup @bind-Visible="Open"
         HeaderText="@GetHeaderText()"
         CloseButtonClick="ChiudiPopup"
         CloseOnOutsideClick="true"
         ShowFooter="false"
         Width="@GetPopupWidth()"
         Height="@GetPopupHeight()"
         MaxWidth="@GetPopupMaxWidth()"
         CssClass="gestione-tabelle-popup">
    <BodyContentTemplate>
        <div class="Popup-Gestione-Tabelle-Content" style="@GetPopupContentStyle()">
            @switch (TabellaSelezionata)
            {
                case "Composizione":
                    <CareLabelComposizioni></CareLabelComposizioni>
                    break;

                case "Posizione":
                    <CareLabelPosizioni></CareLabelPosizioni>
                    break;

                case "Aggiungi Riga":
                    <CareLabelAggiungiRiga
                        ArticoloSelezionato="@ArticoloSelezionato"
                        OnSalvataggioCompletato="ChiudiPopup">
                    </CareLabelAggiungiRiga>
                    break;

                case "Modifica Riga":
                    <CareLabelModificaRiga
                        ArticoloSelezionato="@ArticoloSelezionato"
                        ComposizioneSelezionata="@ComposizioneInModifica"
                        PosizioneSelezionata="@PosizioneInModifica"
                        OnModificaCompletata="ChiudiPopup">
                    </CareLabelModificaRiga>
                    break;

                case "":
                    <span>Nulla Selezionato</span>
                    break;

                default:
                    <span>Errore</span>
                    break;
            }
        </div>
    </BodyContentTemplate>
</DxPopup>

@if (ArticoloSelezionato != null)
{
	<DxFormLayout>
		<DxFormLayoutGroup ColSpanMd="12" Caption="CareLabel">
			<DxFormLayoutItem Context="context2" ColSpanMd="12">
				<div class="carelabel-container">
					<div class="carelabel-toolbar">
						<div class="carelabel-toolbar-left">
							<DxButton Click="Posizione" Text="Posizione" RenderStyle="ButtonRenderStyle.Secondary" />
							<DxButton Click="Composizione" Text="Composizione" RenderStyle="ButtonRenderStyle.Secondary" />
						</div>
						<div class="carelabel-toolbar-right">
							<DxButton Text="Aggiungi Riga" Click="() => AggiungiRiga()" RenderStyle="ButtonRenderStyle.Primary" />
						</div>
					</div>

					@if (Righe.Any())
					{
						<div class="carelabel-table-wrapper">
							<table class="carelabel-table">
								<thead>
									<tr>
										<th class="carelabel-col-pos">Posizione</th>
										<th class="carelabel-col-comp">Composizione</th>
										<th class="carelabel-col-actions"></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var riga in Righe)
									{
										<tr>
											<td class="carelabel-col-pos">
												<div class="carelabel-cell-pos">
													@if (riga.Posizione != null)
													{
														<span class="carelabel-badge carelabel-badge-pos">@riga.Posizione.Posizione</span>
													}
													else
													{
														<span class="carelabel-na">NA</span>
													}
												</div>
											</td>
											<td class="carelabel-col-comp">
												<div class="carelabel-cell-comp">
													@if (riga.Composizione != null)
													{
														<span class="carelabel-badge carelabel-badge-comp">@riga.Composizione.Composizione</span>
													}
													else
													{
														<span class="carelabel-na">NA</span>
													}
												</div>
											</td>
											<td class="carelabel-col-actions">
												<div class="carelabel-actions">
													<DxButton Click="() => ModificaRiga(riga)" RenderStyle="ButtonRenderStyle.None">
														<img src="images/modifytablestyle_16x16.png" class="Image-Command-Column" alt="Modifica" />
													</DxButton>
													<DxButton Click="() => EliminaRiga(riga)" RenderStyle="ButtonRenderStyle.None">
														<img src="images/delete_16x16.png" class="Image-Command-Column" alt="Elimina" />
													</DxButton>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
					else
					{
						<div class="carelabel-empty">
							<span class="text-muted fst-italic">Nulla Selezionato</span>
						</div>
					}
				</div>
			</DxFormLayoutItem>
		</DxFormLayoutGroup>

		<DxFormLayoutGroup ColSpanMd="6" Caption="Label">
		</DxFormLayoutGroup>

		<DxFormLayoutGroup ColSpanMd="6" Caption="Altro">
		</DxFormLayoutGroup>
	</DxFormLayout>
}

@code {

	[Parameter]
	public BasiAll? ArticoloSelezionato { get; set; }

	[Parameter]
	public EventCallback AggiornaDati { get; set; }

	private record RigaCareLabel(int Slot, TabComposizione? Composizione, TabComposizionePo? Posizione);

	private List<RigaCareLabel> Righe = new();

	private TabComposizione? ComposizioneInModifica;
	private TabComposizionePo? PosizioneInModifica;

	bool Open = false;
	bool loading = false;
	string TabellaSelezionata = "";

	private string? ultimoArticoloCd;

	protected override async Task OnParametersSetAsync()
	{
		if (ArticoloSelezionato != null && ArticoloSelezionato.Cd != ultimoArticoloCd)
		{
			ultimoArticoloCd = ArticoloSelezionato.Cd;
			await CaricaComposizioni();
		}
	}

	private static int? GetIdComp(BasiAll a, int slot) => slot switch
	{
		1 => a.IdComp1,
		2 => a.IdComp2,
		3 => a.IdComp3,
		4 => a.IdComp4,
		5 => a.IdComp5,
		_ => null
	};

	private static int? GetIdPos(BasiAll a, int slot) => slot switch
	{
		1 => a.IdPos1,
		2 => a.IdPos2,
		3 => a.IdPos3,
		4 => a.IdPos4,
		5 => a.IdPos5,
		_ => null
	};

	private static bool SlotPieno(int? id) => id.HasValue && id.Value > 0;

	private static void ClearSlot(BasiAll a, int slot)
	{
		switch (slot)
		{
			case 1: a.IdPos1 = null; a.IdComp1 = null; break;
			case 2: a.IdPos2 = null; a.IdComp2 = null; break;
			case 3: a.IdPos3 = null; a.IdComp3 = null; break;
			case 4: a.IdPos4 = null; a.IdComp4 = null; break;
			case 5: a.IdPos5 = null; a.IdComp5 = null; break;
		}
	}

	private async Task CaricaComposizioni()
	{
		Righe.Clear();
		if (ArticoloSelezionato == null) return;

		using var context = await DbFactory.CreateDbContextAsync();

		// ArticoloSelezionato e' la copia in memoria caricata quando la riga e' stata
		// selezionata nella griglia: non si aggiorna da sola dopo un salvataggio fatto
		// altrove, quindi va riletta dal DB per vedere subito le modifiche appena fatte.
		var articoloAggiornato = await context.BasiAlls.AsNoTracking().FirstOrDefaultAsync(a => a.Cd == ArticoloSelezionato.Cd) ?? ArticoloSelezionato;

		for (var slot = 1; slot <= 5; slot++)
		{
			var idComp = GetIdComp(articoloAggiornato, slot);
			var idPos = GetIdPos(articoloAggiornato, slot);

			if (!SlotPieno(idComp) && !SlotPieno(idPos)) continue;

			TabComposizione? composizione = SlotPieno(idComp)
				? await context.TabComposiziones.FirstOrDefaultAsync(x => x.Id == idComp)
				: null;
			TabComposizionePo? posizione = SlotPieno(idPos)
				? await context.TabComposizionePos.FirstOrDefaultAsync(x => x.Id == idPos)
				: null;

			Righe.Add(new RigaCareLabel(slot, composizione, posizione));
		}
	}

	private void Posizione()
	{
		TabellaSelezionata = "Posizione";
		Open = true;
		StateHasChanged();
	}

	private void Composizione()
	{
		TabellaSelezionata = "Composizione";
		Open = true;
		StateHasChanged();
	}

	private async Task ChiudiPopup()
	{
		Open = false;
		TabellaSelezionata = "";
		await CaricaComposizioni();
		await AggiornaDati.InvokeAsync();
		StateHasChanged();
	}

	void AggiungiRiga()
	{
		TabellaSelezionata = "Aggiungi Riga";
		Open = true;
		StateHasChanged();
	}

	private async Task EliminaRiga(RigaCareLabel riga)
	{
		if (ArticoloSelezionato == null) return;

		var confermato = await JS.InvokeAsync<bool>("confirm", "Vuoi davvero eliminare questa combinazione Posizione/Composizione?");
		if (!confermato) return;

		loading = true;
		StateHasChanged();
		try
		{
			using var context = await DbFactory.CreateDbContextAsync();
			var articolo = await context.BasiAlls.FirstOrDefaultAsync(a => a.Cd == ArticoloSelezionato.Cd);
			if (articolo != null)
			{
				ClearSlot(articolo, riga.Slot);
				await context.SaveChangesAsync();
			}

			await CaricaComposizioni();
			await AggiornaDati.InvokeAsync();
		}
		finally
		{
			loading = false;
			StateHasChanged();
		}
	}

	void ModificaRiga(RigaCareLabel riga)
	{
		ComposizioneInModifica = riga.Composizione;
		PosizioneInModifica = riga.Posizione;
		TabellaSelezionata = "Modifica Riga";
		Open = true;
		StateHasChanged();
	}

	private string GetHeaderText()
	{
		return TabellaSelezionata switch
		{
			"Composizione" => "Composition",
			"Posizione" => "Position",
			"Aggiungi Riga" => "AddRow",
			"Modifica Riga" => "Edit",
			_ => ""
		};
	}

	private string GetPopupWidth()
	{
		return TabellaSelezionata switch
		{
			"Aggiungi Riga" or "Modifica Riga" => "500px",
			_ => "90%"
		};
	}

	private string GetPopupMaxWidth()
	{
		return TabellaSelezionata switch
		{
			"Aggiungi Riga" or "Modifica Riga" => "95vw",
			_ => "90vw"
		};
	}

	private string GetPopupHeight()
	{
		return TabellaSelezionata switch
		{
			"Aggiungi Riga" or "Modifica Riga" => "auto",
			_ => "85vh"
		};
	}

	private string GetPopupContentStyle()
	{
		return TabellaSelezionata switch
		{
			"Aggiungi Riga" or "Modifica Riga" => "overflow-x: hidden;",
			_ => ""
		};
	}
}
