@page "/login"
@layout EasyLab.Components.Layout.LoginLayout
@rendermode InteractiveServer
@using EasyLab.Servizi
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject NavigationManager Navigation
@inject StateKeeperService StateKeeper
@inject ProtectedSessionStorage SessionStorage

<PageTitle>Login | EasyPLM</PageTitle>

<div class="login-container">
    <div class="login-overlay"></div>
    
    <div class="login-card">
        <div class="login-logo-container">
            <img src="/images/EasyPlmSVG.svg" alt="EasyPLM Logo" class="login-logo" />
        </div>
        
        <h3 class="login-title">Fashion PLM</h3>
        
        <div class="form-group">
            <label for="username" class="form-label">Username</label>
            <input type="text" id="username" class="form-control" @bind="Username" placeholder="Username" @onkeyup="HandleKeyUp" />
        </div>
        
        <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input type="password" id="password" class="form-control" @bind="Password" placeholder="••••••••" @onkeyup="HandleKeyUp" />
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-message">@ErrorMessage</div>
        }

        <div class="login-actions">
            <button class="btn-login" @onclick="Accedi">Accedi</button>
            <button class="btn-clear" @onclick="Svuota">Pulisci</button>
        </div>
        
        <div class="footer-text">
            © 2026 EasyPLM - Digital Transformation for Fashion
        </div>
    </div>
</div>

@code {
    private string Username { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(StateKeeper.CurrentUsername))
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Accedi();
        }
    }

    private async Task Accedi()
    {
        // Validazione base richiesta dall'utente: se nome utente non è vuoto procediamo
        if (!string.IsNullOrWhiteSpace(Username) && !string.IsNullOrWhiteSpace(Password))
        {
            // In una situazione reale qui si verificherebbe la password
            // Se l'accesso va a buon fine, impostiamo l'utente
            StateKeeper.CurrentUsername = Username.ToUpper();
            StateKeeper.NotifyStateChanged();

            // Salva l'utente nella session storage per persistere al reload
            await SessionStorage.SetAsync("currentUsername", StateKeeper.CurrentUsername);

            // Reindirizziamo alla home dopo il successo
            Navigation.NavigateTo("/");
        }
        else
        {
            ErrorMessage = "Errore";
        }
    }

    private void Svuota()
    {
        Username = string.Empty;
        Password = string.Empty;
        ErrorMessage = string.Empty;
    }
}
