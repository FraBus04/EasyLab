@if (loading)
{
    <Loading></Loading>
}
else if (Reticolo != null)
{
    <div class="d-flex flex-column gap-3">
        <DxCheckBox Checked="@CkColUnico" CheckedChanged="@((bool v) => OnCheckboxChanged(v))">Colore Unico</DxCheckBox>

        @if (CkColUnico)
        {
            var primoColA = ColoriArticoloA.FirstOrDefault();
            @if (primoColA != null)
            {
                var mapp = _coloriReticolo.FirstOrDefault();
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted" style="font-size:0.85rem;">Colore Unico:</span>
                    <DxComboBox Data="@ColoriArticoloB"
                                Value="@mapp?.BCdAllcol"
                                ValueChanged="@((string? v) => SalvaMappaturaColore(primoColA.Cd, v))"
                                TextFieldName="ParteCol"
                                ValueFieldName="Cd"
                                NullText="—"
                                FilteringMode="DataGridFilteringMode.Contains"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                style="width:200px;" />
                </div>
            }
        }
        else
        {
            <div class="d-flex flex-wrap gap-3">
                @foreach (var colA in ColoriArticoloA)
                {
                    var ca = colA;
                    var mapp = _coloriReticolo.FirstOrDefault(c => c.ACdAllcol == ca.Cd);
                    <div class="d-flex flex-column gap-1">
                        <span class="badge" style="background-color:#ff8c00; font-size:0.75rem;">@ca.ParteCol</span>
                        <DxComboBox Data="@ColoriArticoloB"
                                    Value="@mapp?.BCdAllcol"
                                    ValueChanged="@((string? v) => SalvaMappaturaColore(ca.Cd, v))"
                                    TextFieldName="ParteCol"
                                    ValueFieldName="Cd"
                                    NullText="—"
                                    FilteringMode="DataGridFilteringMode.Contains"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                    style="width:160px;" />
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">Nessuna riga selezionata.</p>
}

@code {
    [Parameter] public Bom3Reticolo? Reticolo { get; set; }
    [Parameter] public EventCallback OnModifica { get; set; }

    private bool loading = true;
    private bool CkColUnico = false;
    private int? _previousReticoloId;

    private List<BasiAllcolori> ColoriArticoloA = new();
    private List<BasiAllcolori> ColoriArticoloB = new();
    private List<Bom3DetailCol> _coloriReticolo = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Reticolo != null && Reticolo.Id != _previousReticoloId)
        {
            _previousReticoloId = Reticolo.Id;
            loading = true;
            try
            {
                await CaricaDati();
            }
            finally
            {
                loading = false;
            }
        }
    }

    private async Task CaricaDati()
    {
        using var ctx = await DbFactory.CreateDbContextAsync();

        ColoriArticoloA = await ctx.BasiAllcoloris.AsNoTracking()
            .Where(x => x.CdAll == Reticolo!.ACdAll)
            .OrderBy(x => x.OrdPm)
            .ToListAsync();

        ColoriArticoloB = await ctx.BasiAllcoloris.AsNoTracking()
            .Where(x => x.CdAll == Reticolo!.BCdAll)
            .OrderBy(x => x.OrdPm)
            .ToListAsync();

        _coloriReticolo = await ctx.Bom3DetailCols.AsNoTracking()
            .Where(c => c.IdRigaReticolo == Reticolo!.Id)
            .ToListAsync();

        CkColUnico = Reticolo!.CkColUnico;
    }

    private async Task SalvaMappaturaColore(string cdAllcolA, string? cdAllcolB)
    {
        using var ctx = await DbFactory.CreateDbContextAsync();

        if (CkColUnico)
        {
            var tuttiEsistenti = await ctx.Bom3DetailCols
                .Where(c => c.IdRigaReticolo == Reticolo!.Id)
                .ToListAsync();
            ctx.Bom3DetailCols.RemoveRange(tuttiEsistenti);

            if (!string.IsNullOrEmpty(cdAllcolB))
            {
                foreach (var colA in ColoriArticoloA)
                {
                    ctx.Bom3DetailCols.Add(new Bom3DetailCol
                    {
                        IdRigaReticolo = Reticolo!.Id,
                        AIdContatto = Reticolo.AIdContatto,
                        AIdStag = Reticolo.AIdStag,
                        ACdAll = Reticolo.ACdAll,
                        ACdAllcol = colA.Cd,
                        Ver = Reticolo.Ver,
                        BCdAll = Reticolo.BCdAll ?? "",
                        BCdAllcol = cdAllcolB,
                    });
                }
            }
        }
        else
        {
            var existing = await ctx.Bom3DetailCols
                .FirstOrDefaultAsync(c => c.IdRigaReticolo == Reticolo!.Id && c.ACdAllcol == cdAllcolA);

            if (!string.IsNullOrEmpty(cdAllcolB))
            {
                if (existing == null)
                    ctx.Bom3DetailCols.Add(new Bom3DetailCol
                    {
                        IdRigaReticolo = Reticolo!.Id,
                        AIdContatto = Reticolo.AIdContatto,
                        AIdStag = Reticolo.AIdStag,
                        ACdAll = Reticolo.ACdAll,
                        ACdAllcol = cdAllcolA,
                        Ver = Reticolo.Ver,
                        BCdAll = Reticolo.BCdAll ?? "",
                        BCdAllcol = cdAllcolB,
                    });
                else
                    existing.BCdAllcol = cdAllcolB;
            }
            else if (existing != null)
            {
                ctx.Bom3DetailCols.Remove(existing);
            }
        }

        await ctx.SaveChangesAsync();
        await CaricaDati();
        await OnModifica.InvokeAsync();
        StateHasChanged();
    }

    private async Task OnCheckboxChanged(bool newValue)
    {
        using var ctx = await DbFactory.CreateDbContextAsync();

        var reticolo = await ctx.Bom3Reticolos.FindAsync(Reticolo!.Id);
        if (reticolo != null)
        {
            reticolo.CkColUnico = newValue;
            reticolo.DataUpd = DateTime.Now;
            await ctx.SaveChangesAsync();
        }

        if (newValue)
        {
            var primoColoreB = _coloriReticolo.FirstOrDefault()?.BCdAllcol;

            var tuttiEsistenti = await ctx.Bom3DetailCols
                .Where(c => c.IdRigaReticolo == Reticolo!.Id)
                .ToListAsync();
            ctx.Bom3DetailCols.RemoveRange(tuttiEsistenti);

            if (!string.IsNullOrEmpty(primoColoreB))
            {
                foreach (var colA in ColoriArticoloA)
                {
                    ctx.Bom3DetailCols.Add(new Bom3DetailCol
                    {
                        IdRigaReticolo = Reticolo!.Id,
                        AIdContatto = Reticolo.AIdContatto,
                        AIdStag = Reticolo.AIdStag,
                        ACdAll = Reticolo.ACdAll,
                        ACdAllcol = colA.Cd,
                        Ver = Reticolo.Ver,
                        BCdAll = Reticolo.BCdAll ?? "",
                        BCdAllcol = primoColoreB,
                    });
                }
            }

            await ctx.SaveChangesAsync();
        }

        await CaricaDati();
        CkColUnico = newValue;
        await OnModifica.InvokeAsync();
        StateHasChanged();
    }
}
