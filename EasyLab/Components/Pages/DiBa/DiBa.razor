    private async Task ConfermaElimina()
    {
        if (VersioneSelezionataElimina == null) return;

        loading = true;
        StateHasChanged();

        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();

            var righeSorgente = await ctx.Bom3Reticolos
                .Where(x => x.ACdAll == ArticoloSelezionato!.Cd && x.Ver == VersioneSelezionataElimina)
                .OrderBy(x => x.Seq)
                .ToListAsync();

            var idSorgente = righeSorgente.Select(r => r.Id).ToList();

            var coloriSorgente = await ctx.Bom3DetailCols
                .Where(c => idSorgente.Contains(c.IdRigaReticolo))
                .ToListAsync();

            var misureSorgente = await ctx.Bom3DetailMis
                .Where(m => idSorgente.Contains(m.IdRigaReticolo))
                .ToListAsync();

            ctx.Bom3DetailCols.RemoveRange(coloriSorgente);
            ctx.Bom3DetailMis.RemoveRange(misureSorgente);
            ctx.Bom3Reticolos.RemoveRange(righeSorgente);

            await ctx.SaveChangesAsync();
            VersioneSelezionata = 0;
            await caricaLookup();
        }
        catch (Exception)
        {
        }
        finally
        {
            Open = false;
            loading = false;
            StateHasChanged();
        }
    }
