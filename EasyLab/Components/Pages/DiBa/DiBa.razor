    private async Task ConfermaDuplica()
    {
        if (VersioneSelezionataDuplica == null) return;

        loading = true;
        StateHasChanged();

        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();

            var righeSorgente = await ctx.Bom3Reticolos
                .Where(x => x.ACdAll == ArticoloSelezionato!.Cd && x.Ver == VersioneSelezionataDuplica)
                .OrderBy(x => x.Seq)
                .ToListAsync();

            var idSorgente = righeSorgente.Select(r => r.Id).ToList();

            var coloriSorgente = await ctx.Bom3DetailCols
                .Where(c => idSorgente.Contains(c.IdRigaReticolo))
                .ToListAsync();

            var misureSorgente = await ctx.Bom3DetailMis
                .Where(m => idSorgente.Contains(m.IdRigaReticolo))
                .ToListAsync();

            int nuovaVersione = Versioni.Where(v => v >= 0).DefaultIfEmpty(0).Max() + 1;
            VersioneSelezionata = nuovaVersione;

            var mapping = new List<(Bom3Reticolo Nuova, int VecchioId)>();
            foreach (var riga in righeSorgente)
            {
                var nuova = new Bom3Reticolo
                {
                    ATipo = riga.ATipo,
                    AIdContatto = riga.AIdContatto,
                    AIdStag = riga.AIdStag,
                    ACdAll = riga.ACdAll,
                    ACkSemilav = riga.ACkSemilav,
                    Ver = nuovaVersione,
                    IdFase = riga.IdFase,
                    Seq = riga.Seq,
                    BTipo = riga.BTipo,
                    BCdAll = riga.BCdAll,
                    BCkSemilav = riga.BCkSemilav,
                    Um = riga.Um,
                    CkMp = riga.CkMp,
                    CkMrp = riga.CkMrp,
                    CkFabb = riga.CkFabb,
                    CkMatMis = riga.CkMatMis,
                    CkColUnico = riga.CkColUnico,
                    CkContr = riga.CkContr,
                    Posizione = riga.Posizione,
                    Note = riga.Note,
                    Tp = riga.Tp,
                    Tp2 = riga.Tp2,
                    Tp3 = riga.Tp3,
                    IdPack = riga.IdPack,
                    IdMatColPack = riga.IdMatColPack,
                    IdPos = riga.IdPos,
                    CdRegolaCons = riga.CdRegolaCons,
                    IdRegMis = riga.IdRegMis,
                    Cons = riga.Cons,
                    ACdAllmis = riga.ACdAllmis,
                    BCdAllmis = riga.BCdAllmis,
                    DataIns = DateTime.Now,
                    DataUpd = DateTime.Now,
                };
                ctx.Bom3Reticolos.Add(nuova);
                mapping.Add((nuova, riga.Id));
            }

            await ctx.SaveChangesAsync();

            foreach (var (nuova, vecchioId) in mapping)
            {
                foreach (var col in coloriSorgente.Where(c => c.IdRigaReticolo == vecchioId))
                {
                    ctx.Bom3DetailCols.Add(new Bom3DetailCol
                    {
                        IdRigaReticolo = nuova.Id,
                        AIdContatto = col.AIdContatto,
                        AIdStag = col.AIdStag,
                        ACdAll = col.ACdAll,
                        ACdAllcol = col.ACdAllcol,
                        Ver = nuovaVersione,
                        BCdAll = col.BCdAll,
                        BCdAllcol = col.BCdAllcol,
                        DataIns = DateTime.Now,
                    });
                }
                foreach (var mis in misureSorgente.Where(m => m.IdRigaReticolo == vecchioId))
                {
                    ctx.Bom3DetailMis.Add(new Bom3DetailMi
                    {
                        IdRigaReticolo = nuova.Id,
                        AIdContatto = mis.AIdContatto,
                        AIdStag = mis.AIdStag,
                        ACdAll = mis.ACdAll,
                        ACdAllmis = mis.ACdAllmis,
                        Ver = nuovaVersione,
                        BCdAll = mis.BCdAll,
                        BCdAllmis = mis.BCdAllmis,
                        Cons = mis.Cons,
                        DataIns = DateTime.Now,
                    });
                }
            }

            await ctx.SaveChangesAsync();
            await caricaLookup();
        }
        catch (Exception)
        {
        }
        finally
        {
            Open = false;
            loading = false;
            StateHasChanged();
        }
    }

