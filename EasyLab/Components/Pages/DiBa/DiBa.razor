    private async Task UP(Bom3Reticolo riga)
    {
        if (DataSource == null) return;
        var sotto = DataSource.Where(x => x.Seq > riga.Seq).OrderBy(x => x.Seq).FirstOrDefault();
        if (sotto == null) return;

        loading = true;
        int tmp = riga.Seq;
        riga.Seq = sotto.Seq;
        sotto.Seq = tmp;
        using var context = await DbFactory.CreateDbContextAsync();
        context.Update(riga);
        context.Update(sotto);
        await context.SaveChangesAsync();
        await caricaLookup();
        loading = false;
    }

    private async Task DOWN(Bom3Reticolo riga)
    {
        if (DataSource == null) return;
        var sopra = DataSource.Where(x => x.Seq < riga.Seq).OrderByDescending(x => x.Seq).FirstOrDefault();
        if (sopra == null) return;

        loading = true;
        int tmp = riga.Seq;
        riga.Seq = sopra.Seq;
        sopra.Seq = tmp;
        using var context = await DbFactory.CreateDbContextAsync();
        context.Update(riga);
        context.Update(sopra);
        await context.SaveChangesAsync();
        await caricaLookup();
        loading = false;
    }

