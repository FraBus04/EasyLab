@if (loading)
{
    <Loading></Loading>
}
else if (Reticolo != null)
{
    <div class="d-flex flex-column gap-3">
        @if (!MisureArticoloA.Any())
        {
            <p class="text-muted">Nessuna misura configurata per l'articolo.</p>
        }
        else
        {
            <div class="d-flex flex-wrap gap-3">
                @foreach (var misA in MisureArticoloA)
                {
                    var ma = misA;
                    var mapp = _misureReticolo.FirstOrDefault(m => m.ACdAllmis == ma.Cd);
                    <div class="d-flex flex-column gap-1">
                        <span class="badge" style="background-color:#ff8c00; font-size:0.75rem;">@(ma.ParteMis ?? ma.Cd)</span>
                        <DxComboBox Data="@MisureArticoloB"
                                    Value="@mapp?.BCdAllmis"
                                    ValueChanged="@((string? v) => SalvaMappaturaTaglie(ma.Cd, v))"
                                    TextFieldName="ParteMis"
                                    ValueFieldName="Cd"
                                    NullText="—"
                                    FilteringMode="DataGridFilteringMode.Contains"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                    style="width:160px;" />
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">Nessuna riga selezionata.</p>
}

@code {
    [Parameter] public Bom3Reticolo? Reticolo { get; set; }
    [Parameter] public EventCallback OnModifica { get; set; }

    private bool loading = true;
    private int? _previousReticoloId;

    private List<BasiAllmisure> MisureArticoloA = new();
    private List<BasiAllmisure> MisureArticoloB = new();
    private List<Bom3DetailMi> _misureReticolo = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Reticolo != null && Reticolo.Id != _previousReticoloId)
        {
            _previousReticoloId = Reticolo.Id;
            loading = true;
            try
            {
                await CaricaDati();
            }
            finally
            {
                loading = false;
            }
        }
    }

    private async Task CaricaDati()
    {
        using var ctx = await DbFactory.CreateDbContextAsync();

        MisureArticoloA = await ctx.BasiAllmisures.AsNoTracking()
            .Where(x => x.CdAll == Reticolo!.ACdAll)
            .OrderBy(x => x.IdSetOrd).ThenBy(x => x.Cd)
            .ToListAsync();

        MisureArticoloB = await ctx.BasiAllmisures.AsNoTracking()
            .Where(x => x.CdAll == Reticolo!.BCdAll)
            .OrderBy(x => x.IdSetOrd).ThenBy(x => x.Cd)
            .ToListAsync();

        _misureReticolo = await ctx.Bom3DetailMis.AsNoTracking()
            .Where(m => m.IdRigaReticolo == Reticolo!.Id)
            .ToListAsync();
    }

    private async Task SalvaMappaturaTaglie(string cdAllmisA, string? cdAllmisB)
    {
        using var ctx = await DbFactory.CreateDbContextAsync();

        var existing = await ctx.Bom3DetailMis
            .FirstOrDefaultAsync(m => m.IdRigaReticolo == Reticolo!.Id && m.ACdAllmis == cdAllmisA);

        if (!string.IsNullOrEmpty(cdAllmisB))
        {
            if (existing == null)
                ctx.Bom3DetailMis.Add(new Bom3DetailMi
                {
                    IdRigaReticolo = Reticolo!.Id,
                    AIdContatto = Reticolo.AIdContatto,
                    AIdStag = Reticolo.AIdStag,
                    ACdAll = Reticolo.ACdAll,
                    ACdAllmis = cdAllmisA,
                    Ver = Reticolo.Ver,
                    BCdAll = Reticolo.BCdAll ?? "",
                    BCdAllmis = cdAllmisB,
                    Cons = Reticolo.Cons,
                    DataIns = DateTime.Now,
                    DataUpd = DateTime.Now,
                });
            else
            {
                existing.BCdAllmis = cdAllmisB;
                existing.DataUpd = DateTime.Now;
            }
        }
        else if (existing != null)
        {
            ctx.Bom3DetailMis.Remove(existing);
        }

        await ctx.SaveChangesAsync();
        await CaricaDati();
        await OnModifica.InvokeAsync();
        StateHasChanged();
    }
}
